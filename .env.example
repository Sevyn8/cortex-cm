# Ithina Admin Backend — Environment variables template
#
# Copy this file to .env in the same directory:
#   cp .env.example .env
# Then fill in values appropriate to your environment.
#
# .env is gitignored. Never commit it.
#
# Variables are grouped by purpose. Some are required for the app to start;
# others have sensible defaults and are listed for visibility.

# ============================================================================
# Database
# ============================================================================

# SQLAlchemy connection string for async psycopg3.
# Local dev (Docker Postgres): the value below works out of the box.
# Cloud (via Cloud SQL Auth Proxy): use localhost:5432 (proxy listens locally).
DATABASE_URL=postgresql+psycopg://user_admin_backend:password_admin_backend@localhost:5432/ithina_platform_db

# Schema where admin-backend tables live. Per-environment configurable.
# Set on local Postgres via: ALTER ROLE <role> SET search_path TO <schema>, public;
DB_SCHEMA=core

# Connection pool tuning (optional; defaults are sensible)
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=5
# DB_POOL_TIMEOUT_SECONDS=30

# ============================================================================
# Authentication
# ============================================================================

# Switch between stub auth (build phase) and Auth0 (production).
# Values: STUB | AUTH0
AUTH_CLIENT_MODE=STUB

# JWT issuer (must match what the auth provider issues).
# Local stub: any value, just be consistent.
# Auth0: https://<your-tenant>.us.auth0.com/  (note trailing slash)
JWT_ISSUER=https://stub-issuer.local/

# JWT audience (must match what the auth provider sets as 'aud').
# Auth0: this is the API identifier you registered in Auth0 Dashboard.
JWT_AUDIENCE=https://api.ithina.com

# Path to the RSA public key for verifying JWT signatures.
# Local stub: keys/jwt_public.pem (generated at Step 2.1).
# Auth0: leave empty; the AuthClient fetches from JWKS URL automatically.
JWT_PUBLIC_KEY_PATH=keys/jwt_public.pem

# Path to the RSA private key for minting test JWTs (stub mode only).
# In production with AUTH_CLIENT_MODE=AUTH0, this is not used.
JWT_PRIVATE_KEY_PATH=keys/jwt_private.pem

# Auth0 settings (only needed when AUTH_CLIENT_MODE=AUTH0).
# AUTH0_DOMAIN=ithina-prod.us.auth0.com
# AUTH0_JWKS_URL=https://ithina-prod.us.auth0.com/.well-known/jwks.json

# Token expiry default in seconds (used by stub when minting test tokens).
TOKEN_DEFAULT_TTL_SECONDS=3600

# ============================================================================
# Application
# ============================================================================

# Region the app is deployed to. Affects per-region behaviour and logging.
# Values: EU | US | LOCAL
APP_REGION=LOCAL

# Environment name. Affects logging, error verbosity, and observability defaults.
# Values: development | staging | production
ENVIRONMENT=development

# Log level. INFO in production, DEBUG only when actively investigating locally.
# Values: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Service version reported by /api/v1/health and the FastAPI OpenAPI
# `info.version` field. Local dev: leave unset; the default reads
# pyproject.toml's [project].version via importlib.metadata.
# Deployed images: set to the image tag (e.g., v0.1.4) so /api/v1/health
# matches the running container. Two ways to set it on a deployed image:
#   (1) Bake at build time:    docker build --build-arg SERVICE_VERSION=v0.1.4 ...
#   (2) Override at deploy time: gcloud run deploy --set-env-vars SERVICE_VERSION=v0.1.4
# (2) wins over (1) when both are set.
# SERVICE_VERSION=v0.1.4

# Whether to log incoming request bodies (NEVER enable in production).
# Defaults to false. Used only for local debugging of request shapes.
# LOG_REQUEST_BODIES=false

# ============================================================================
# Observability
# ============================================================================

# Prometheus metrics endpoint port (default 8000, same as app).
# Set to a different port if you want metrics on a separate port.
# METRICS_PORT=8000

# Service name reported in logs and metrics.
SERVICE_NAME=admin-backend

# ============================================================================
# CORS
# ============================================================================

# Allowed origins for CORS (comma-separated).
# Local dev: include the frontend dev server URL.
# Production: include the frontend production URL.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================================
# Cloud (production / cloud-deploy only)
# ============================================================================

# GCP project ID. Used for Workload Identity, Secret Manager, Cloud SQL connection.
# GCP_PROJECT_ID=ithina-admin-dev

# Cloud SQL instance connection name (project:region:instance).
# Used by Cloud SQL Auth Proxy when running in GKE.
# CLOUD_SQL_INSTANCE=ithina-admin-dev:us-central1:admin-master

# ============================================================================
# Build / Test
# ============================================================================

# Used by tests to point at a separate test database (optional).
# Defaults to DATABASE_URL if unset.
# TEST_DATABASE_URL=postgresql+psycopg://user_admin_backend:password_admin_backend@localhost:5432/ithina_platform_db_test

# ============================================================================
# Notes
# ============================================================================
#
# Required at startup (app refuses to start if missing):
#   - DATABASE_URL
#   - DB_SCHEMA
#   - AUTH_CLIENT_MODE
#   - JWT_ISSUER
#   - JWT_AUDIENCE
#   - JWT_PUBLIC_KEY_PATH (when AUTH_CLIENT_MODE=STUB)
#   - APP_REGION
#   - ENVIRONMENT
#
# Required only in cloud deployments:
#   - GCP_PROJECT_ID
#   - CLOUD_SQL_INSTANCE
#
# Required only when AUTH_CLIENT_MODE=AUTH0:
#   - AUTH0_DOMAIN
#   - AUTH0_JWKS_URL
#
# Set in Secret Manager (not in .env) for production:
#   - DATABASE_URL (with prod credentials)
#   - JWT signing secrets (if using HS256 in some legacy path)
